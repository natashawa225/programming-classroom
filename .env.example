# Supabase (public client config)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Lightweight teacher dashboard password gate (server-only; do NOT prefix with NEXT_PUBLIC_)
TEACHER_DASHBOARD_PASSWORD=
# Optional: require a username too
TEACHER_DASHBOARD_USERNAME=
# Optional: session cookie lifetime (seconds). Default is 8 hours.
TEACHER_DASHBOARD_SESSION_MAX_AGE_SECONDS=28800

